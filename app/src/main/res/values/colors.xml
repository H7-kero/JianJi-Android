<?xml version="1.0" encoding="utf-8"?>
<!--
    颜色资源文件
    定义应用中使用的颜色
    可以在代码中通过 R.color.xxx 引用
-->
<resources>
    <!-- 主题色：主色 -->
    <color name="primary">#FF6750A4</color>
    <color name="purple_500">#FF6750A4</color>
    <color name="purple_700">#FF4F378B</color>
    <!-- 主题色：容器色 -->
    <color name="primary_container">#FFEADDFF</color>
    <!-- 错误色 -->
    <color name="error">#FFB3261E</color>
    <!-- 次要颜色 -->
    <color name="teal_200">#FF81C5D2</color>
    <color name="teal_700">#FF0D4F4F</color>
    <!-- 背景色 -->
    <color name="background">#FFFAFAFA</color>
    <color name="on_background">#FF1C1B1F</color>
    <color name="surface">#FFFFFFFF</color>
    <color name="on_surface">#FF1C1B1F</color>
    <color name="white">#FFFFFFFF</color>
    <color name="black">#FF000000</color>
</resources>